# ===========================================================
# Biddr client env — local development template.
# Copy to `.env` (gitignored) for local dev. In production
# (Netlify), set the same variables in the Netlify dashboard
# under Site settings → Environment variables.
# ===========================================================

# Relative API base. Keep as `/api` so the browser always
# hits the same origin and Netlify's /api/* → Render rewrite
# forwards the request server-to-server. No CORS needed.
VITE_API_BASE=/api

# Empty by default → the browser uses the current origin for
# Socket.IO, and Netlify's /socket.io/* rewrite does the rest.
VITE_SOCKET_BASE=

# Web OAuth client ID from Google Cloud Console
# (APIs & Services → Credentials → Web application).
# Same value the server uses, just exposed to the browser
# for the Google Identity Services button.
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com