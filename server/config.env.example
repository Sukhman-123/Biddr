# =============================================================
# Biddr server config — local development template.
# Copy this file to `config.env` (which is gitignored) and fill
# in real values. Production uses Render's dashboard env vars
# instead of this file.
# =============================================================

# Port the Express server listens on. Render overrides this
# automatically (it sets PORT to 10000 for free web services),
# but for local dev we use 5001.
PORT=5001

# MongoDB Atlas connection string. Use the standard
# "mongodb+srv://..." URI. Atlas Network Access must allow
# 0.0.0.0/0 (or the Render egress range) so Render can connect.
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/biddr?retryWrites=true&w=majority

# Comma-separated list of allowed origins for CORS.
# Local dev:    http://localhost:5173
# Netlify prod: https://biddr.netlify.app
# Netlify preview: https://deploy-preview-123--biddr.netlify.app
# Custom domain (if you add one): https://biddr.live
CLIENT_URL=http://localhost:5173

# JWT signing secret. Generate with:  openssl rand -hex 64
# MUST be a long random string in production. Rotating this logs
# every user out, so don't change it lightly.
JWT_SECRET=change_this_to_a_long_random_string_in_production

# Web OAuth client ID from Google Cloud Console
# (APIs & Services → Credentials → OAuth client ID → Web application).
# Leave empty in dev to disable Google sign-in.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Resend transactional email config for password reset emails.
# Create an API key in Resend and keep it private. Never commit the real key.
# For early testing, Resend supports onboarding@resend.dev. For production,
# use a verified sending domain such as noreply@your-domain.com.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Biddr <onboarding@resend.dev>
SUPPORT_EMAIL=support@biddr.app
